    "build:desktop": "tauri build",
    "test": "pnpm --filter @jtool/core test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "diff": "^8.0.4",
    "js-yaml": "^4.1.1",
    "jsondiffpatch": "^0.7.3",
    "jsonpath-plus": "^10.4.0",
    "papaparse": "^5.5.3",
    "xml-js": "^1.6.11"
  }
}
